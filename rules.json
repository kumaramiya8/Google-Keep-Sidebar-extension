[
  {
    "id": 1,
    "priority": 1,
    "action": {
      "type": "modifyHeaders",
      "requestHeaders": [
        { "header": "Sec-Fetch-Dest", "operation": "set", "value": "document" },
        { "header": "Sec-Fetch-Site", "operation": "set", "value": "same-origin" },
        { "header": "Sec-Ch-Ua-Mobile", "operation": "set", "value": "?1" },
        { "header": "Sec-Ch-Ua-Platform", "operation": "set", "value": "\"iOS\"" },
        { "header": "Referer", "operation": "set", "value": "https://keep.google.com/" },
        { "header": "Origin", "operation": "set", "value": "https://keep.google.com" },
        {
          "header": "User-Agent",
          "operation": "set",
          "value": "Mozilla/5.0 (iPhone; CPU iPhone OS 16_6 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.6 Mobile/15E148 Safari/604.1"
        },
        { "header": "Viewport-Width", "operation": "set", "value": "350" }
      ],
      "responseHeaders": [
        {
          "header": "X-Frame-Options",
          "operation": "remove"
        },
        {
          "header": "Content-Security-Policy",
          "operation": "remove"
        }
      ]
    },
    "condition": {
      "urlFilter": "||keep.google.com",
      "resourceTypes": [
        "sub_frame",
        "script",
        "xmlhttprequest",
        "stylesheet",
        "image",
        "font",
        "other"
      ],
      "excludedTopDomains": ["google.com", "keep.google.com"]
    }
  }
]
