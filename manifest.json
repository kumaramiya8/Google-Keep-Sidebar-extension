{
  "manifest_version": 3,
  "name": "Google Keep Sidebar",
  "version": "1.0.0",
  "description": "Brings Google Keep as a native side panel on any website, enabling quick capture and easy notes management.",
  "permissions": [
    "sidePanel",
    "declarativeNetRequest",
    "contextMenus",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.keep.google.com/*",
    "*://keep.google.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "keep_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open Google Keep Sidebar",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "open-keep-sidebar": {
      "suggested_key": {
        "default": "Alt+Shift+K",
        "mac": "Alt+Shift+K"
      },
      "description": "Open Google Keep Sidebar"
    }
  }
}
